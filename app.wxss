/* app.wxss - 全局样式 */

/* 适老化设计：大字体、高对比度 */
page {
  font-size: 36rpx;
  line-height: 1.6;
  color: #333333;
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

/* 主题色 */
.primary-color {
  color: #4A90D9;
}

.primary-bg {
  background-color: #4A90D9;
}

/* 大按钮样式 - 方便老年人点击 */
.btn-large {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  border-radius: 50rpx;
  background-color: #4A90D9;
  color: #FFFFFF;
  text-align: center;
}

.btn-large:active {
  background-color: #3A7BC8;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title-large {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
}

.title-medium {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
}

/* 文本样式 */
.text-primary {
  color: #4A90D9;
}

.text-secondary {
  color: #666666;
}

.text-hint {
  color: #999999;
  font-size: 30rpx;
}

/* 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 20rpx 0;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
