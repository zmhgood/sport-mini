/* pages/goal/progress.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.section {
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.progress-summary {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 500;
}

/* ========== 锻炼模式样式 ========== */
.exercise-mode {
  
}

.exercise-header {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.exercise-header .exercise-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
}

.exercise-header .exercise-info {
  flex: 1;
}

.exercise-header .exercise-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 12rpx;
}

.exercise-header .exercise-desc {
  font-size: 28rpx;
  color: #64748B;
}

/* 进度条区域 */
.progress-section {
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.progress-section .progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-section .progress-label {
  font-size: 28rpx;
  color: #64748B;
}

.progress-section .progress-percent {
  font-size: 32rpx;
  font-weight: 600;
  color: #22C55E;
}

.progress-section .progress-bar {
  width: 100%;
}

/* 组数选择区域 */
.sets-section {
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.sets-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.set-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.set-item.checked {
  background: #EFF6FF;
  border-color: #3B82F6;
}

.set-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #CBD5E1;
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.set-item.checked .set-checkbox {
  border-color: #3B82F6;
  background: #3B82F6;
}

.checkbox-inner {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.set-label {
  flex: 1;
  font-size: 30rpx;
  color: #1E293B;
  font-weight: 500;
}

.set-reps {
  font-size: 28rpx;
  color: #64748B;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 进度查看模式样式 ========== */
.overall-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.overall-progress .progress-bar {
  flex: 1;
}

.overall-progress .progress-percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #22C55E;
  width: 80rpx;
  text-align: right;
}

/* 分段进度条 */
.segmented-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.segmented-progress {
  flex: 1;
  height: 20rpx;
  display: flex;
  border-radius: 10rpx;
  overflow: hidden;
  background: #E5E7EB;
}

.segmented-progress.small {
  height: 12rpx;
  border-radius: 6rpx;
}

.progress-segment {
  height: 100%;
  position: relative;
  opacity: 0.4;
}

.progress-segment:first-child {
  border-radius: 10rpx 0 0 10rpx;
}

.progress-segment:last-child {
  border-radius: 0 10rpx 10rpx 0;
}

.progress-segment:only-child {
  border-radius: 10rpx;
}

.segmented-progress.small .progress-segment:first-child {
  border-radius: 6rpx 0 0 6rpx;
}

.segmented-progress.small .progress-segment:last-child {
  border-radius: 0 6rpx 6rpx 0;
}

.segmented-progress.small .progress-segment:only-child {
  border-radius: 6rpx;
}

.segment-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: linear-gradient(135deg, #FFFFFF 0%, rgba(255,255,255,0.6) 100%);
}

/* 动作图例 */
.progress-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-name {
  font-size: 24rpx;
  color: #64748B;
}

/* 动作卡片 */
.exercise-list {

}

.exercise-card {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.exercise-card:last-child {
  margin-bottom: 0;
}

.exercise-status.pending {
  background: #FEF3C7;
  color: #D97706;
}

.exercise-progress {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.control-btn {
  width: 56rpx;
  height: 56rpx;
  background: #3B82F6;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
}

.control-btn:active {
  background: #2563EB;
}

.progress-value {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 500;
  min-width: 100rpx;
  text-align: center;
}

.exercise-info {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 成员进度 */
.member-progress-list {

}

.member-progress-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.member-progress-item:last-child {
  border-bottom: none;
}

.member-header {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 28rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
}

.progress-text {
  font-size: 24rpx;
  color: #64748B;
  width: 100rpx;
}
