<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 右上角当前家庭 -->
    <view class="header-family" wx:if="{{isLoggedIn && currentFamily.id}}" bindtap="goToSetting" data-id="family">
      <text class="header-family-text">{{currentFamily.name}}</text>
    </view>
    
    <view class="user-card" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatar_url || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
      <text class="username">{{userInfo.nick_name || '老年朋友'}}</text>
      <text class="user-desc" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
      <text class="user-desc" wx:else>坚持锻炼，健康长寿</text>
    </view>
    <view class="user-card login-card" wx:else bindtap="handleLogin">
      <image class="avatar" src="/images/default-avatar.svg" mode="aspectFill"></image>
      <text class="username">点击登录</text>
      <text class="user-desc">登录后同步锻炼记录</text>
    </view>

    <!-- 统计数据 -->
    <view class="stats-card card">
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalDays}}</text>
        <text class="stat-label">累计锻炼天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalSets}}</text>
        <text class="stat-label">完成动作组数</text>
      </view>
    </view>

    <!-- 按家庭统计（可展开） -->
    <view class="family-stats-card card" wx:if="{{familyStats.length > 0}}">
      <view class="family-stats-header" bindtap="toggleFamilyStats">
        <text class="family-stats-title">各家庭贡献</text>
        <text class="family-stats-toggle">{{showFamilyStats ? '▲' : '▼'}}</text>
      </view>
      <view class="family-stats-list" wx:if="{{showFamilyStats}}">
        <view class="family-stat-item" wx:for="{{familyStats}}" wx:key="family_id">
          <view class="family-stat-info">
            <text class="family-stat-name">{{item.family_name}}</text>
            <text class="family-stat-detail">{{item.total_days}}天 · {{item.total_sets}}组</text>
          </view>
          <view class="family-stat-bar">
            <view class="family-stat-progress" style="width: {{item.total_sets / statistics.totalSets * 100}}%;"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{isLoggedIn}}">
    <view class="section-header flex-between">
      <text class="section-title">锻炼记录</text>
      <text class="more-btn" bindtap="goToHistory">更多</text>
    </view>

    <!-- 柱状图 -->
    <view class="chart-card card">
      <!-- 周范围标题 -->
      <view class="chart-header">
        <view class="nav-btn {{canGoPrev ? '' : 'disabled'}}" bindtap="prevWeek">
          <text class="nav-arrow">‹</text>
        </view>
        <text class="week-range">{{weekRange}}</text>
        <view class="nav-btn {{canGoNext ? '' : 'disabled'}}" bindtap="nextWeek">
          <text class="nav-arrow">›</text>
        </view>
      </view>

      <!-- 柱状图主体 -->
      <view class="chart-container">
        <view class="chart-bar {{day.count > 0 ? 'has-data' : ''}}" wx:for="{{weekStats}}" wx:for-item="day" wx:key="date"
              bindtap="goToGoalFromChart" data-id="{{day.goalId}}" data-count="{{day.count}}" data-goalids="{{day.goalIds}}" data-date="{{day.date}}">
          <view class="bar-wrapper">
            <view class="bar">
              <view class="bar-fill" style="height: {{day.barPercent || 0}}%;"></view>
            </view>
          </view>
          <text class="bar-value">{{day.count > 0 ? day.count : ''}}</text>
          <text class="bar-label">{{day.weekday}}</text>
          <text class="bar-date">{{day.dateStr}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置项 -->
  <view class="settings-section">
    <text class="section-title">设置</text>
    
    <view class="settings-list card">
      <view class="setting-item flex-between" wx:for="{{settings}}" wx:key="id" wx:if="{{!item.hidden || currentFamily.id}}" bindtap="goToSetting" data-id="{{item.id}}">
        <view class="setting-left flex-row">
          <text class="setting-icon">{{item.icon}}</text>
          <text class="setting-name">{{item.name}}</text>
        </view>
        <view class="setting-right flex-row">
          <text class="setting-value">{{item.value}}</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>
    
    <!-- 退出登录 -->
    <view class="logout-section" wx:if="{{isLoggedIn}}">
      <button class="logout-btn" bindtap="handleLogout">退出登录</button>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">银龄健身 v1.0.0</text>
    <text class="footer-text">专为老年人设计的肌肉锻炼助手</text>
  </view>
</view>
