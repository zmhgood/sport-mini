<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image wx:if="{{systemConfig.logo_url}}" class="logo-img" src="{{systemConfig.logo_url}}" mode="aspectFit"></image>
    <view wx:else class="logo">💪</view>
    <text class="app-name">{{systemConfig.site_name || '银龄健身'}}</text>
    <text class="slogan">科学锻炼，健康生活</text>
  </view>

  <!-- 微信登录 -->
  <view class="wechat-login" wx:if="{{!showWechatForm}}">
    <button 
      class="wechat-btn" 
      bindtap="wechatLogin"
      lang="zh_CN"
    >
      <text class="wechat-icon">👤</text>
      微信登录
    </button>
  </view>

  <!-- 微信登录 - 填写头像昵称表单 -->
  <view class="wechat-login-form" wx:if="{{showWechatForm}}">
    <view class="wechat-form-card">
      <text class="form-tip">请完善您的头像和昵称</text>
      
      <!-- 头像选择 -->
      <button 
        class="avatar-wrapper" 
        open-type="chooseAvatar" 
        bind:chooseavatar="onChooseAvatar"
      >
        <image class="avatar-img" src="{{wechatAvatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <text class="avatar-hint">点击选择头像</text>
      </button>
      
      <!-- 昵称输入 -->
      <view class="nickname-wrapper">
        <text class="label">昵称</text>
        <input 
          type="nickname" 
          class="nickname-input"
          placeholder="请输入昵称"
          value="{{wechatNickName}}"
          bindinput="onNickNameInput"
          bindblur="onNickNameInput"
        />
      </view>
      
      <!-- 确认登录按钮 -->
      <button class="confirm-btn" bindtap="confirmWechatLogin">
        确认登录
      </button>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tips">
    <text>登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
