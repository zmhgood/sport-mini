/* pages/profile-edit/profile-edit.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.textarea-item {
  flex-direction: column;
  align-items: flex-start;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

.picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.picker-text {
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  font-size: 30rpx;
  color: #333;
  background: #f9f9f9;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.btn-area {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  border-radius: 45rpx;
  border: none;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-save {
  background: #3B82F6;
  color: #fff;
}

.btn-save[disabled] {
  background: #93C5FD;
}
