/* pages/profile/profile.wxss */

.container {
  padding-bottom: 120rpx;
}

/* 用户区域 */
.user-section {
  background: linear-gradient(135deg, #4A90D9 0%, #5BA0E9 100%);
  padding: 40rpx 30rpx 80rpx;
}

.user-card {
  text-align: center;
  margin-bottom: 30rpx;
}

.login-card {
  opacity: 0.9;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  margin-bottom: 20rpx;
}

.username {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.user-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-top: -50rpx;
  padding: 30rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E5E5;
}

/* 历史记录 */
.history-section {
  padding: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.more-btn {
  font-size: 28rpx;
  color: #4A90D9;
}

.history-list {
  margin-top: 20rpx;
}

.history-item {
  margin-bottom: 20rpx;
}

.history-header {
  margin-bottom: 20rpx;
}

.history-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.history-duration {
  font-size: 28rpx;
  color: #4A90D9;
}

.history-exercises {
  gap: 16rpx;
}

.exercise-tag {
  padding: 10rpx 20rpx;
  background: #F5F7FA;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
}

/* 设置 */
.settings-section {
  padding: 20rpx;
}

.settings-list {
  margin-top: 20rpx;
}

.setting-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  align-items: center;
}

.setting-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.setting-name {
  font-size: 32rpx;
  color: #333333;
}

.setting-right {
  align-items: center;
}

.setting-value {
  font-size: 28rpx;
  color: #999999;
  margin-right: 10rpx;
}

.arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #CCCCCC;
  margin-bottom: 10rpx;
}
