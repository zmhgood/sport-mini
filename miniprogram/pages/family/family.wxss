/* pages/family/family.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 未加入家庭 */
.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 36rpx;
  color: #1E293B;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 60rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 80%;
}

.btn-primary {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: none;
}

.btn-secondary {
  background: #FFFFFF;
  color: #3B82F6;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: 2rpx solid #3B82F6;
}

/* 家庭卡片 */
.family-card {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
}

.family-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.family-name {
  font-size: 40rpx;
  font-weight: 600;
}

.member-count {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.invite-section {
  background: rgba(255, 255, 255, 0.15);
  padding: 24rpx;
  border-radius: 16rpx;
}

.invite-label {
  font-size: 26rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 12rpx;
}

.invite-code-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invite-code {
  font-size: 48rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
}

.copy-btn {
  background: rgba(255, 255, 255, 0.3);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.refresh-btn {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 16rpx;
  text-align: right;
}

/* 板块 */
.section {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.section-action {
  font-size: 28rpx;
  color: #3B82F6;
}

/* 成员列表 */
.member-list {
  
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  color: #1E293B;
  display: block;
}

.member-role {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
  display: inline-block;
}

.member-role.admin {
  color: #3B82F6;
  background: #EFF6FF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #EF4444;
  padding: 8rpx 16rpx;
}

.action-btn.primary {
  color: #3B82F6;
}

/* 目标列表 */
.goal-list {

}

.goal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-info {
  flex: 1;
}

.goal-name {
  font-size: 30rpx;
  color: #1E293B;
  display: block;
}

.goal-members {
  font-size: 26rpx;
  color: #64748B;
  margin-top: 8rpx;
  display: block;
}

.goal-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
}

.empty-list {
  text-align: center;
  padding: 40rpx;
  color: #94A3B8;
  font-size: 28rpx;
}

/* 退出 */
.leave-section {
  margin: 40rpx 24rpx;
}

.btn-danger {
  background: #FFFFFF;
  color: #EF4444;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 48rpx;
  border: 2rpx solid #EF4444;
}

/* 家庭选择器 */
.family-selector {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.selector-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  color: #1E293B;
}

.selector-arrow {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 操作按钮组 */
.action-buttons {
  margin: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-buttons .btn-secondary {
  background: #FFFFFF;
  color: #3B82F6;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 48rpx;
  border: 2rpx solid #3B82F6;
}

.action-buttons .btn-danger {
  font-size: 30rpx;
  padding: 24rpx 0;
}
