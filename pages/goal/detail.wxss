/* pages/goal/detail.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

.goal-header {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  padding: 48rpx 32rpx;
  text-align: center;
  color: #FFFFFF;
}

.goal-name {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.goal-stats {
  font-size: 28rpx;
  opacity: 0.9;
}

.stat-item {
  
}

.stat-divider {
  margin: 0 16rpx;
  opacity: 0.5;
}

.section {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-action {
  font-size: 28rpx;
  color: #3B82F6;
}

/* 进度列表 */
.progress-list {

}

.progress-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.progress-item:last-child {
  border-bottom: none;
}

.member-row {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
}

.progress-text {
  font-size: 26rpx;
  color: #64748B;
  width: 100rpx;
  text-align: right;
}

/* 分段进度条 */
.segmented-progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.segmented-progress {
  flex: 1;
  height: 16rpx;
  display: flex;
  border-radius: 8rpx;
  overflow: hidden;
  background: #E5E7EB;
}

.progress-segment {
  height: 100%;
  position: relative;
}

.progress-segment:first-child {
  border-radius: 8rpx 0 0 8rpx;
}

.progress-segment:last-child {
  border-radius: 0 8rpx 8rpx 0;
}

.progress-segment:only-child {
  border-radius: 8rpx;
}

.segment-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.25;
}

.segment-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
}

/* 动作图例 */
.progress-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-name {
  font-size: 22rpx;
  color: #64748B;
}

/* 动作列表 */
.exercise-list {

}

.exercise-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.exercise-item:last-child {
  border-bottom: none;
}

.exercise-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: #E0E7FF;
  flex-shrink: 0;
}

.exercise-info {
  flex: 1;
  min-width: 0;
}

.exercise-name {
  font-size: 30rpx;
  color: #1E293B;
  display: block;
  font-weight: 500;
}

.exercise-target {
  font-size: 26rpx;
  color: #64748B;
  display: block;
  margin-top: 8rpx;
}

.exercise-sets {
  font-size: 26rpx;
  color: #3B82F6;
  display: block;
  margin-top: 8rpx;
}

.btn-start {
  width: 160rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: none;
  margin-left: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
}

.btn-start.btn-done {
  background: linear-gradient(135deg, #9CA3AF 0%, #6B7280 100%);
}

.btn-start::after {
  border: none;
}

/* 成员网格 */
.member-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.member-item {
  width: calc(25% - 18rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.member-item .member-avatar {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  margin-right: 0;
}

.member-item .member-name {
  font-size: 24rpx;
  text-align: center;
}

/* 成员进度列表 */
.member-progress-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-progress-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.member-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8rpx;
}

.member-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-bottom: 6rpx;
}

.member-name-small {
  font-size: 22rpx;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.member-progress-text {
  font-size: 20rpx;
  color: #64748B;
}

.mini-progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E2E8F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.mini-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6 0%, #8B5CF6 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
}
