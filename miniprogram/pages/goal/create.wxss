/* pages/goal/create.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

.section {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #3B82F6;
}

.add-btn {
  font-size: 28rpx;
  color: #3B82F6;
}

.name-input {
  width: 100%;
  height: 88rpx;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 成员选择 */
.member-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.member-item {
  width: calc(25% - 18rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #F8FAFC;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
}

.member-item.selected {
  background: #EFF6FF;
  border-color: #3B82F6;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.member-name {
  font-size: 26rpx;
  color: #1E293B;
}

.check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #3B82F6;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 动作列表 */
.exercise-list {

}

.exercise-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.exercise-info {
  flex: 1;
}

.exercise-name {
  font-size: 30rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 12rpx;
}

.exercise-config {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.config-label {
  font-size: 26rpx;
  color: #64748B;
}

.config-input {
  width: 80rpx;
  height: 56rpx;
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.remove-btn {
  font-size: 40rpx;
  color: #EF4444;
  padding: 0 16rpx;
}

.empty-list {
  text-align: center;
  padding: 40rpx;
  color: #94A3B8;
  font-size: 28rpx;
}

/* 提交 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.modal-close {
  font-size: 48rpx;
  color: #94A3B8;
}

.modal-body {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
}

.exercise-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
}

.exercise-option.selected {
  background: #EFF6FF;
  border-color: #3B82F6;
}

.option-name {
  font-size: 30rpx;
  color: #1E293B;
  flex: 1;
}

.option-target {
  font-size: 26rpx;
  color: #64748B;
  margin-right: 16rpx;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  background: #3B82F6;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F1F5F9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.selected-count {
  font-size: 28rpx;
  color: #64748B;
}

.btn-confirm {
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  padding: 0 32rpx;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F1F5F9;
}

.category-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748B;
  background: #F1F5F9;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.category-tab.active {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-weight: 500;
}

/* 动作选项 */
.option-left {
  flex: 1;
}

.option-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.option-category {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #FFFFFF;
}

.option-category.upper {
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
}

.option-category.core {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
}

.option-category.lower {
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
}
