/* pages/goal/goal.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 24rpx;
}

.goal-list {

}

.goal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.goal-info {
  flex: 1;
}

.goal-name {
  font-size: 34rpx;
  color: #1E293B;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.goal-meta {
  font-size: 26rpx;
  color: #64748B;
}

.meta-divider {
  margin: 0 8rpx;
}

.goal-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #94A3B8;
}
