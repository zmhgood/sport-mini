<!--pages/goal/goal.wxml-->
<view class="container">
  <view class="goal-list" wx:if="{{goals.length > 0}}">
    <view class="goal-item" wx:for="{{goals}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="goal-info">
        <text class="goal-name">{{item.name}}</text>
        <view class="goal-meta">
          <text class="meta-item">{{item.memberCount || 0}}人参与</text>
          <text class="meta-divider">·</text>
          <text class="meta-item">{{item.exerciseCount || 0}}个动作</text>
        </view>
      </view>
      <text class="goal-arrow">›</text>
    </view>
  </view>
  <view class="empty" wx:else>
    <text class="empty-text">暂无目标</text>
  </view>
</view>
