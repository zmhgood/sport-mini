/* pages/muscle/muscle.wxss */

.container {
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #F0FDF4 0%, #F8FAFC 30%);
  min-height: 100vh;
}

/* 标签栏 */
.tabs {
  background: #FFFFFF;
  padding: 20rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border-radius: 0 0 32rpx 32rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #64748B;
  position: relative;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item.active {
  color: #10B981;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #10B981, #34D399);
  border-radius: 3rpx;
}

/* 肌肉介绍 */
.muscle-intro {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.1);
  border: 1rpx solid rgba(16, 185, 129, 0.1);
}

.intro-header {
  align-items: center;
}

.intro-icon {
  font-size: 100rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  padding: 16rpx;
  border-radius: 20rpx;
}

.intro-text {
  flex: 1;
}

.intro-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.muscle-tags {
  gap: 12rpx;
}

.muscle-tag {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #059669;
  font-size: 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 锻炼板块 */
.exercise-section {
  padding: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}

/* 锻炼卡片 */
.exercise-card {
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F1F5F9;
}

.card-header {
  margin-bottom: 20rpx;
}

.exercise-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
}

.difficulty-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.difficulty-tag.easy {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #059669;
}

.difficulty-tag.medium {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #D97706;
}

.exercise-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
}

.card-info {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.info-row {
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #94A3B8;
  width: 160rpx;
}

.info-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}


