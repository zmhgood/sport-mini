<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-card" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <text class="username">{{userInfo.nickName || '老年朋友'}}</text>
      <text class="user-desc">坚持锻炼，健康长寿</text>
    </view>
    <view class="user-card login-card" wx:else bindtap="handleLogin">
      <image class="avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
      <text class="username">点击登录</text>
      <text class="user-desc">登录后同步锻炼记录</text>
    </view>

    <!-- 统计数据 -->
    <view class="stats-card card">
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalDays}}</text>
        <text class="stat-label">累计天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalExercises}}</text>
        <text class="stat-label">完成动作</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalMinutes}}</text>
        <text class="stat-label">锻炼分钟</text>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section">
    <view class="section-header flex-between">
      <text class="section-title">锻炼记录</text>
      <text class="more-btn">查看全部</text>
    </view>
    
    <view class="history-list">
      <view class="history-item card" wx:for="{{historyList}}" wx:key="date" bindtap="viewHistory" data-date="{{item.date}}">
        <view class="history-header flex-between">
          <text class="history-date">{{item.date}}</text>
          <text class="history-duration">{{item.duration}}分钟</text>
        </view>
        <view class="history-exercises flex-row flex-wrap">
          <text class="exercise-tag" wx:for="{{item.exercises}}" wx:key="*this" wx:for-item="exercise">{{exercise}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置项 -->
  <view class="settings-section">
    <text class="section-title">设置</text>
    
    <view class="settings-list card">
      <view class="setting-item flex-between" wx:for="{{settings}}" wx:key="id" bindtap="goToSetting" data-id="{{item.id}}">
        <view class="setting-left flex-row">
          <text class="setting-icon">{{item.icon}}</text>
          <text class="setting-name">{{item.name}}</text>
        </view>
        <view class="setting-right flex-row">
          <text class="setting-value">{{item.value}}</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">银龄健身 v1.0.0</text>
    <text class="footer-text">专为老年人设计的肌肉锻炼助手</text>
  </view>
</view>
