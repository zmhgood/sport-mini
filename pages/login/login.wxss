/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 50%, #EC4899 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.login-container::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.login-container::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  left: -150rpx;
  width: 500rpx;
  height: 500rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  padding: 60rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.logo {
  font-size: 140rpx;
  margin-bottom: 24rpx;
  display: block;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.15));
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.app-name {
  display: block;
  font-size: 60rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 4rpx;
}

.slogan {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 60rpx;
  padding: 8rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  border-radius: 52rpx;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item.active {
  background: #FFFFFF;
  color: #3B82F6;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 表单样式 */
.login-form {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.form-item {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #E2E8F0;
  padding: 32rpx 0;
  transition: border-color 0.3s;
}

.form-item:focus-within {
  border-color: #3B82F6;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-item .label {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.form-item input {
  flex: 1;
  font-size: 34rpx;
  color: #1E293B;
}

.form-item input::placeholder {
  color: #94A3B8;
}

.code-btn {
  font-size: 28rpx;
  color: #3B82F6;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  padding: 16rpx 28rpx;
  border: none;
  border-radius: 32rpx;
  min-width: 180rpx;
  font-weight: 500;
}

.code-btn.disabled {
  color: #94A3B8;
  background: #F1F5F9;
}

.code-btn::after {
  border: none;
}

.login-btn {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 54rpx;
  margin-top: 48rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.35);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
}

/* 微信登录 */
.wechat-login {
  padding: 24rpx 48rpx;
  position: relative;
  z-index: 1;
}

.wechat-btn {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  background: #FFFFFF;
  color: #1E293B;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.wechat-btn::after {
  border: none;
}

.wechat-btn:active {
  transform: scale(0.98);
}

.wechat-icon {
  margin-right: 16rpx;
  font-size: 48rpx;
  flex-shrink: 0;
}

/* 微信登录表单 */
.wechat-login-form {
  position: relative;
  z-index: 1;
}

.wechat-form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.form-tip {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #1E293B;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.avatar-wrapper {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  padding: 0;
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #E2E8F0;
  background: #F1F5F9;
}

.avatar-hint {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 16rpx;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #E2E8F0;
  padding: 24rpx 0;
  margin-bottom: 32rpx;
}

.nickname-wrapper .label {
  font-size: 32rpx;
  color: #1E293B;
  margin-right: 24rpx;
  font-weight: 500;
}

.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: #1E293B;
}

.confirm-btn {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 54rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.35);
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  transform: scale(0.98);
}

/* 提示 */
.tips {
  text-align: center;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.tips text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}
